# Secret Key for authentication (create a strong random string)
# The code also accepts NEXT_PUBLIC_SECRET_KEY for backward compatibility.
SECRET_KEY=your-secret-key-here-change-this

# Encryption key for session data (32 character string)
# The code also accepts NEXT_PUBLIC_ENCRYPTION_KEY for backward compatibility.
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Shadowbroker backend URL (if deploying backend separately)
BACKEND_URL=https://your-shadowbroker-backend.com

# Optional: Rate limiting
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=900000

# Optional: Session duration in milliseconds
SESSION_DURATION=3600000
